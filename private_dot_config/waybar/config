{
  "margin-top" : 5,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 30,
    "modules-left": [
	"hyprland/window"
    ],
    "modules-center": [
      "hyprland/workspaces",
      "tray",
    ],
    "modules-right": [
    "pulseaudio",
    "network",
    "battery",
    "clock#date", "clock#time",
    "custom/notification",
    ],
    
    "hyprland/window": {
      "format": "{}",
      "max-length": 35,
      "rewrite": {
        "": "No Windows Open!"
      },
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "sort-by-number": true,
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10,
    },
    

    "clock#date": {
        "type": "clock",
        "format": "{:%b %d %Y}",
        "tooltip": false
    },
    "clock#time": {
        "type": "clock",
        "format": "{:%I:%M %p}",
        "tooltip": false
    },


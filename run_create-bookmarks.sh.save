#!/bin/bash

mkdir -p $HOME/Bookmarks
cd $HOME/Bookmarks
rm *

ln -s / 01_root
ln -s /dev 02_devices

ln -s $HOME 10_home
ln -s $HOME/.config 11_config
ln -s $HOME/.local/share/
ln -s $HOME/Bookmarks 12_bookmarks

ln -s $HOME/3D\ Models 20_3d
ln -s $HOME/Applications 21_apps
ln -s $HOME/Documents 22_Docs
ln -s $HOME/Downloads 23_downloads
ln -s $HOME/Music 24_music
ln -s $HOME/Pictures 25_pics
ln -s $HOME/Projects 26_projects
ln -s $HOME/Videos 27_vids

ln -s $HOME/Pictures 30_pics
ln -s $HOME/Pictures/Wallpapers 31_wallpapers
ln -s $HOME/Pictures/Screenshots 32_screenshots
